# ── Anthropic (required) ───────────────────────────────────────────────────────
# Get your key at https://console.anthropic.com
ANTHROPIC_API_KEY=your_api_key_here

# ── Charles Schwab (optional — for live trading) ───────────────────────────────
# Register at https://developer.schwab.com → Create App
# Callback URL must be set to: https://127.0.0.1
SCHWAB_API_KEY=your_schwab_app_key_here
SCHWAB_API_SECRET=your_schwab_app_secret_here

# ── Itradedash insider intelligence (optional) ─────────────────────────────────
# Point to your local Itradedash SQLite DB for direct reads (fastest).
# Clone from: https://github.com/SileniusAuLune/Itradedash
# Windows example:
# ITRADEDASH_DB=C:/Users/YourUser/Documents/Itradedash/data/insider_trades.db
#
# Fallback: if DB path not set, TradeAgent will try the Itradedash Flask API.
# Leave blank to disable API fallback.
ITRADEDASH_DB=
ITRADEDASH_API=http://localhost:8080
