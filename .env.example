# ── Anthropic (required) ───────────────────────────────────────────────────────
# Get your key at https://console.anthropic.com
ANTHROPIC_API_KEY=your_api_key_here

# ── Charles Schwab (optional — for live trading) ───────────────────────────────
# Register at https://developer.schwab.com → Create App
# Callback URL must be set to: https://127.0.0.1
SCHWAB_API_KEY=your_schwab_app_key_here
SCHWAB_API_SECRET=your_schwab_app_secret_here
